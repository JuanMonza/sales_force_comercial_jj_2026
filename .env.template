# ─── Variables de entorno ─────────────────────────────────────────────────────
# Copia este archivo a .env y completa los valores reales.
# NUNCA versiones el archivo .env en git.
#
# Generar JWT_SECRET seguro:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"

# Shared
NODE_ENV=development

# Tenant
DEFAULT_TENANT_ID=<uuid-del-tenant-principal>

# Backend
BACKEND_PORT=4000
JWT_SECRET=<genera-un-secreto-aleatorio-de-al-menos-48-chars>
JWT_EXPIRES_IN=8h
DATABASE_URL=postgres://<user>:<password>@postgres:5432/<dbname>
REDIS_URL=redis://redis:6379
CORS_ORIGIN=http://localhost:3000
APPSHEET_API_KEY=<clave-appsheet-minimo-16-caracteres>
APPSHEET_IDEMPOTENCY_TTL_SECONDS=86400
APPSHEET_IDEMPOTENCY_LOCK_TTL_SECONDS=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_DEFAULT_TENANT_ID=<uuid-del-tenant-principal>

# Postgres container
POSTGRES_DB=<nombre-de-la-base-de-datos>
POSTGRES_USER=<usuario-de-postgres>
POSTGRES_PASSWORD=<password-seguro>
